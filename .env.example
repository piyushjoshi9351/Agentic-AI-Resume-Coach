# Example environment variables for local development and deployment

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRE_MINUTES=120

# Database (Postgres recommended in production)
# For local SQLite use: sqlite:///./dev.db
DATABASE_URL=sqlite:///./dev.db

# AI provider: local or gemini
AI_PROVIDER=local

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=

# External APIs (optional)
GOOGLE_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=

# JSearch (optional)
JSEARCH_API_KEY=your_rapidapi_key_here
JSEARCH_API_HOST=jsearch.p.rapidapi.com

# Other runtime flags
LOG_LEVEL=INFO
